    {
      "id": "agents_rule_1_pyarud_reconciliation",
      "label": "Rule 1: pyarud decides after reconciliation",
      "file_type": "rationale",
      "source_file": "/home/akbar/Jupyter_Notebooks/AntiGravity/arabic_diacritization_langgraph/AGENTS.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Before applying the rule that pyarud wins in a disagreement, the system attempts to reconcile case-ending flags programmatically to avoid false-positive disagreements on poetry license."
    },
    {
      "id": "agents_rule_2_locked_verses",
      "label": "Rule 2: Locked Verses",
      "file_type": "rationale",
      "source_file": "/home/akbar/Jupyter_Notebooks/AntiGravity/arabic_diacritization_langgraph/AGENTS.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Once a verse passes pyarud, it is locked. Locked verses are never resubmitted to the diacritizer to avoid the risk of degradation on subsequent passes."
    },
    {
      "id": "agents_rule_3_verification_code_read_only",
      "label": "Rule 3: Verification Code is Read-Only",
      "file_type": "rationale",
      "source_file": "/home/akbar/Jupyter_Notebooks/AntiGravity/arabic_diacritization_langgraph/AGENTS.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "No subagent or custom tool can edit validation logic to prevent agents from hacking or bypassing checkers."
    },
    {
      "id": "agents_rule_4_dataset_writes",
      "label": "Rule 4: Dataset Writes via commit_verse Only",
      "file_type": "rationale",
      "source_file": "/home/akbar/Jupyter_Notebooks/AntiGravity/arabic_diacritization_langgraph/AGENTS.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Dataset writes must go through a dedicated tool that runs a validation check before write, avoiding unsafe direct filesystem edits."
    },
    {
      "id": "agents_rule_5_max_passes",
      "label": "Rule 5: Max 3 Correction Passes",
      "file_type": "rationale",
      "source_file": "/home/akbar/Jupyter_Notebooks/AntiGravity/arabic_diacritization_langgraph/AGENTS.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "To prevent infinite loops and forcing incorrect inputs, correction retries are capped at 3 passes, after which they are logged as unresolved."
    },
    {
      "id": "agents_rule_6_tanwin_fath_bug",
      "label": "Rule 6: tanwīn fatḥ bug on alif maqṣūra",
      "file_type": "concept",
      "source_file": "/home/akbar/Jupyter_Notebooks/AntiGravity/arabic_diacritization_langgraph/AGENTS.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "pyarud miscounts syllables on words ending with tanwin fath on an alif maqsura, requiring phonetic normalization and metadata flags."
    },
